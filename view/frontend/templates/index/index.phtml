<!-- FAQ Category Filter + Accordion (vanilla JS for Luma) -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';
    var wrapper = document.querySelector('.panth-faq-module .faq-wrapper');
    if (!wrapper) return;

    // ═══ ACCORDION ═══
    function initAccordion(container) {
        var headers = (container || wrapper).querySelectorAll('.faq-item-header');
        headers.forEach(function(header) {
            if (header.dataset.accordionBound) return;
            header.dataset.accordionBound = '1';
            header.addEventListener('click', function() {
                var item = header.closest('.faq-item');
                var content = item.querySelector('.faq-item-content');
                var isOpen = content.style.display === 'block';
                content.style.display = isOpen ? 'none' : 'block';
                item.classList.toggle('active', !isOpen);
            });
            header.addEventListener('keypress', function(e) {
                if (e.which === 13 || e.which === 32) { e.preventDefault(); header.click(); }
            });
        });
    }
    initAccordion();

    // ═══ CATEGORY FILTER (client-side show/hide) ═══
    var filterContainer = document.getElementById('faq-filter-options');
    if (filterContainer) {
        var buttons = filterContainer.querySelectorAll('.filter-option');
        var sections = wrapper.querySelectorAll('.faq-category-section');
        var uncategorized = wrapper.querySelector('.faq-uncategorized-section');

        buttons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                var catId = parseInt(btn.getAttribute('data-category-id')) || 0;

                // Update active state
                buttons.forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active');

                // Show/hide sections
                if (catId === 0) {
                    // Show all
                    sections.forEach(function(s) { s.style.display = ''; });
                    if (uncategorized) uncategorized.style.display = '';
                } else {
                    sections.forEach(function(s) {
                        var sectionId = s.getAttribute('id');
                        if (sectionId === 'category-' + catId) {
                            s.style.display = '';
                        } else {
                            s.style.display = 'none';
                        }
                    });
                    if (uncategorized) uncategorized.style.display = 'none';
                }
            });
        });
    }

    // ═══ AJAX SEARCH ═══
    var searchForm = document.getElementById('faq-search-form');
    var searchInput = document.getElementById('faq-search-input');
    var contentDiv = wrapper.querySelector('.faq-content');

    if (searchForm && searchInput && contentDiv) {
        var originalContent = contentDiv.innerHTML;
        var searchTimeout;

        searchForm.addEventListener('submit', function(e) {
            e.preventDefault();
            doSearch();
        });

        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            var q = searchInput.value.trim();
            if (q.length === 0) {
                contentDiv.innerHTML = originalContent;
                initAccordion(contentDiv);
                return;
            }
            if (q.length >= 2) {
                searchTimeout = setTimeout(doSearch, 400);
            }
        });

        function doSearch() {
            var q = searchInput.value.trim();
            if (q.length < 2) return;

            var formKey = '';
            var fkMatch = document.cookie.match(/form_key=([^;]+)/);
            if (fkMatch) formKey = fkMatch[1];
            var fkEl = document.querySelector('input[name="form_key"]');
            if (!formKey && fkEl) formKey = fkEl.value;

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '<?= $block->escapeJs($block->getUrl("faq/ajax/search")) ?>');
            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
            xhr.onload = function() {
                try {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        renderSearchResults(data.results, q, data.count);
                    }
                } catch(ex) {}
            };
            xhr.send('q=' + encodeURIComponent(q) + '&form_key=' + formKey);
        }

        function renderSearchResults(results, query, count) {
            var html = '<div class="search-results-info"><p>Search results for: "' + escapeHtml(query) + '" <span class="results-count">(' + count + ' results)</span></p></div>';
            if (!results || results.length === 0) {
                html += '<div class="message info empty"><div>No FAQs found matching your search.</div></div>';
            } else {
                html += '<div class="faq-items-list">';
                results.forEach(function(item) {
                    html += '<div class="faq-item" data-faq-id="' + item.id + '">'
                        + '<div class="faq-item-header" role="button" tabindex="0">'
                        + '<h3 class="faq-question">' + escapeHtml(item.question) + '</h3>'
                        + '<span class="faq-toggle-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></span>'
                        + '</div>'
                        + '<div class="faq-item-content" style="display:none;">'
                        + '<div class="faq-answer">' + item.answer + '</div>'
                        + '</div></div>';
                });
                html += '</div>';
            }
            contentDiv.innerHTML = html;
            initAccordion(contentDiv);
        }

        function escapeHtml(text) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(text));
            return d.innerHTML;
        }
    }

    // ═══ HELPFUL VOTING ═══
    wrapper.addEventListener('click', function(e) {
        var btn = e.target.closest('.helpful-btn');
        if (!btn) return;
        e.preventDefault();
        var itemId = btn.getAttribute('data-item-id');
        var voteType = btn.classList.contains('helpful-yes') ? 'yes' : 'no';
        var storageKey = 'faq_voted_' + itemId;
        if (localStorage.getItem(storageKey)) return;

        var formKey = '';
        var fkMatch = document.cookie.match(/form_key=([^;]+)/);
        if (fkMatch) formKey = fkMatch[1];
        var fkEl = document.querySelector('input[name="form_key"]');
        if (!formKey && fkEl) formKey = fkEl.value;

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?= $block->escapeJs($block->getUrl("faq/vote/submit")) ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onload = function() {
            try {
                var data = JSON.parse(xhr.responseText);
                if (data.success) {
                    var count = btn.querySelector('.count');
                    var current = parseInt((count.textContent || '0').replace(/[()]/g, '')) || 0;
                    count.textContent = '(' + (current + 1) + ')';
                    localStorage.setItem(storageKey, voteType);
                    btn.closest('.faq-helpful').querySelectorAll('.helpful-btn').forEach(function(b) { b.disabled = true; });
                }
            } catch(ex) {}
        };
        xhr.send('item_id=' + itemId + '&vote=' + voteType + '&form_key=' + formKey);
    });
});
</script>
