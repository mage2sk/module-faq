$isDefaultOpen = $block->isDefaultOpen();
?>

<div class="panth-faq-module">
<div class="faq-wrapper">
    <div class="faq-actions faq-actions-top">
        <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>" class="action back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            <span><?= $block->escapeHtml(__('Back to FAQ')) ?></span>
        </a>
    </div>
    <?php if ($isSearchEnabled): ?>
        <div class="faq-filters">
            <div class="faq-search">
                <form action="<?= $block->escapeUrl($block->getUrl('faq/index/index')) ?>" method="get" id="faq-search-form">
                    <div class="search-field">
                        <input type="text"
                               name="q"
                               id="faq-search-input"
                               placeholder="<?= $block->escapeHtmlAttr(__('Search FAQs...')) ?>"
                               class="input-text" />
                        <button type="submit" class="action search" title="<?= $block->escapeHtmlAttr(__('Search')) ?>">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                            <span><?= $block->escapeHtml(__('Search')) ?></span>
                        </button>
                    </div>
                </form>
            </div>
