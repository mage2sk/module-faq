<!-- FAQ Accordion for Hyva theme -->
<script>
if (typeof require === 'undefined') {
    // Hyva theme - initialize accordion directly
    document.addEventListener('DOMContentLoaded', function() {
        var wrapper = document.querySelector('.widget-faq-section');
        if (!wrapper) return;

        var headers = wrapper.querySelectorAll('.faq-item-header');
        headers.forEach(function(header) {
            header.addEventListener('click', function() {
                var item = header.closest('.faq-item');
                var content = item.querySelector('.faq-item-content');
                var isOpen = content.style.display === 'block';

                // Toggle current item
                if (isOpen) {
                    content.style.display = 'none';
                    item.classList.remove('active');
                } else {
                    content.style.display = 'block';
                    item.classList.add('active');
                }
            });

            // Handle keyboard navigation
            header.addEventListener('keypress', function(e) {
                if (e.which === 13 || e.which === 32) { // Enter or Space
                    e.preventDefault();
                    header.click();
                }
            });
        });
    });
}
</script>

<script type="text/x-magento-init">
{
    ".widget-faq-section": {
        "Panth_Faq/js/faq": {
            "defaultOpen": false
        }
    }
}
</script>

<script>
(function() {
    'use strict';

    function initFaqSearch() {
        var searchInput = document.getElementById('widget-faq-search-input');
        var searchBtn = document.getElementById('widget-faq-search-btn');
        var clearBtn = document.getElementById('widget-faq-clear-btn');
        var faqItems = document.querySelectorAll('.widget-faq-section .faq-item');
        var noResults = null;

        if (!searchInput || !searchBtn || !clearBtn) {
            return;
        }

        // Search functionality
        function performSearch() {
            var query = searchInput.value.toLowerCase().trim();

            if (query === '') {
                showAllItems();
                clearBtn.style.display = 'none';
                return;
            }

            var hasResults = false;

            faqItems.forEach(function(item) {
                var question = item.getAttribute('data-question') || '';
                var answer = item.getAttribute('data-answer') || '';

                if (question.indexOf(query) !== -1 || answer.indexOf(query) !== -1) {
                    item.style.display = '';
                    hasResults = true;
                } else {
                    item.style.display = 'none';
                }
            });

            if (!hasResults) {
                showNoResults();
            } else {
                hideNoResults();
            }

            clearBtn.style.display = '';
        }

        function showAllItems() {
            faqItems.forEach(function(item) {
                item.style.display = '';
            });
            hideNoResults();
        }

        function showNoResults() {
            if (!noResults) {
                noResults = document.createElement('div');
                noResults.className = 'message info empty';
                noResults.innerHTML = '<div>No FAQs found matching your search.</div>';
                var faqContent = document.querySelector('.widget-faq-section .faq-content');
                if (faqContent) {
                    faqContent.insertBefore(noResults, faqContent.firstChild);
                }
            }
            if (noResults) {
                noResults.style.display = '';
            }
        }

        function hideNoResults() {
            if (noResults) {
                noResults.style.display = 'none';
            }
        }

        function clearSearch() {
            searchInput.value = '';
            showAllItems();
            clearBtn.style.display = 'none';
        }

        // Event handlers
        searchBtn.addEventListener('click', performSearch);
        clearBtn.addEventListener('click', clearSearch);

        searchInput.addEventListener('keyup', function(e) {
            if (e.key === 'Enter') {
                performSearch();
            } else if (e.key === 'Escape') {
                clearSearch();
            }
        });

        // Real-time search as you type (debounced)
        var searchTimeout;
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(function() {
                performSearch();
            }, 300);
        });
    }

    // Initialize when DOM is ready - compatible with both Hyva and Luma
    if (typeof require !== 'undefined' && typeof define !== 'undefined') {
        // Luma theme with RequireJS
        require(['jquery'], function($) {
            $(document).ready(function() {
                initFaqSearch();
            });
        });
    } else {
        // Hyva theme or vanilla JS
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                initFaqSearch();
            });
        } else {
            initFaqSearch();
        }
    }
})();
</script>

