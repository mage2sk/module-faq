 *
 * @var $block \Panth\Faq\Block\Faq\Listing
 * @var $escaper \Magento\Framework\Escaper
 */
?>

<div class="faq-page">
    <div class="page-title-wrapper">
        <h1 class="page-title">
            <span class="base" data-ui-id="page-title-wrapper"><?= $escaper->escapeHtml(__('Frequently Asked Questions')) ?></span>
        </h1>
    </div>

    <div class="faq-search-wrapper">
        <div class="faq-search-container">
            <label for="faq-search" class="faq-search-label">
                <?= $escaper->escapeHtml(__('Search FAQs')) ?>
            </label>
            <input
                type="text"
                id="faq-search"
                class="faq-search-input"
                placeholder="<?= $escaper->escapeHtmlAttr(__('Type your question here...')) ?>"
                aria-label="<?= $escaper->escapeHtmlAttr(__('Search FAQ questions')) ?>"
            />
            <span class="faq-search-icon" aria-hidden="true">&#128269;</span>
        </div>
    </div>

    <?php $categories = $block->getCategories(); ?>

    <?php if ($categories->getSize() > 0): ?>
        <div class="faq-categories-wrapper">
            <?php foreach ($categories as $category): ?>
                <?php if ($block->hasItems($category->getId())): ?>
                    <section class="faq-category" data-category-id="<?= $escaper->escapeHtmlAttr($category->getId()) ?>">
                        <div class="faq-category-header">
                            <h2 class="faq-category-title" id="category-<?= $escaper->escapeHtmlAttr($category->getId()) ?>">
                                <?php if ($category->getIcon()): ?>
                                    <span class="faq-category-icon" aria-hidden="true"><?= $escaper->escapeHtml($category->getIcon()) ?></span>
                                <?php endif; ?>
                                <span class="faq-category-name"><?= $escaper->escapeHtml($category->getName()) ?></span>
                            </h2>
                            <?php if ($category->getDescription()): ?>
                                <p class="faq-category-description">
                                    <?= $escaper->escapeHtml($category->getDescription()) ?>
                                </p>
                            <?php endif; ?>
                        </div>

                        <div class="faq-items-accordion">
                            <?php $items = $block->getCategoryItems($category->getId()); ?>
                            <?php if ($items->getSize() > 0): ?>
                                <?php foreach ($items as $item): ?>
                                    <article class="faq-item"
                                             data-item-id="<?= $escaper->escapeHtmlAttr($item->getId()) ?>"
                                             data-category-id="<?= $escaper->escapeHtmlAttr($category->getId()) ?>">
                                        <h3 class="faq-item-header">
                                            <button
                                                class="faq-item-toggle"
                                                type="button"
                                                aria-expanded="false"
                                                aria-controls="<?= $escaper->escapeHtmlAttr($block->getItemAccordionId($category->getId(), $item->getId())) ?>"
                                                data-role="faq-toggle">
                                                <span class="faq-question">
                                                    <?= $escaper->escapeHtml($item->getQuestion()) ?>
                                                </span>
                                                <span class="faq-toggle-icon" aria-hidden="true">
                                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                    </svg>
                                                </span>
                                            </button>
                                        </h3>
                                        <div
                                            class="faq-item-content"
                                            id="<?= $escaper->escapeHtmlAttr($block->getItemAccordionId($category->getId(), $item->getId())) ?>"
                                            role="region"
                                            aria-labelledby="<?= $escaper->escapeHtmlAttr($block->getItemAccordionId($category->getId(), $item->getId())) ?>-label"
                                            hidden>
                                            <div class="faq-answer">
                                                <?= /* @noEscape */ $item->getAnswer() ?>
                                            </div>
                                        </div>
                                    </article>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </div>
                    </section>
                <?php endif; ?>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="faq-no-items">
            <p><?= $escaper->escapeHtml(__('No FAQ items are currently available.')) ?></p>
        </div>
    <?php endif; ?>
</div>

<script type="text/x-magento-init">
{
    ".faq-page": {
        "Panth_Faq/js/faq-listing": {}
    }
}
</script>

