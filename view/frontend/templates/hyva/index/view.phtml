 */

$item = $block->getFaqItem();
$showViewCount = $block->showViewCount();
$isHelpfulVotingEnabled = $block->isHelpfulVotingEnabled();
$formKey = $block->getFormKey();
$voteUrl = $block->getUrl('faq/vote/submit');
?>

<div class="max-w-3xl mx-auto py-4" x-data="{ voted: false }">
    <?php if ($item): ?>
        <!-- Back link -->
        <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>"
           class="inline-flex items-center gap-1.5 text-sm mb-6 transition"
           style="color: var(--color-primary, #0D9488);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            <?= $block->escapeHtml(__('Back to FAQs')) ?>
        </a>

        <!-- Question -->
        <h1 class="text-2xl md:text-3xl font-bold mb-6" style="color: var(--color-fg, #171717);">
            <?= $block->escapeHtml($item->getQuestion()) ?>
        </h1>

        <!-- Answer -->
        <div class="prose max-w-none mb-8" style="color: var(--color-fg-secondary, #404040);">
            <?= /* @noEscape */ $item->getAnswer() ?>
        </div>

        <!-- Meta + Voting -->
        <div class="pt-6" style="border-top: 1px solid var(--color-container-darker, #e5e5e5);">
            <?php if ($showViewCount): ?>
                <p class="text-xs mb-4" style="color: var(--color-fg-muted, #a3a3a3);">
                    <?= $block->escapeHtml(__('%1 views', $item->getViewCount())) ?>
                </p>
            <?php endif; ?>

            <?php if ($isHelpfulVotingEnabled): ?>
                <div class="flex flex-wrap items-center gap-3">
                    <span class="text-sm font-medium" style="color: var(--color-fg-secondary, #525252);">
                        <?= $block->escapeHtml(__('Was this helpful?')) ?>
                    </span>
                    <div class="flex gap-2">
                        <button type="button"
                                class="helpful-btn helpful-yes inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg transition disabled:opacity-50"
                                style="background: var(--color-primary-lighter, #F0FDFA); color: var(--color-primary-darker, #0F766E);"
                                data-item-id="<?= (int)$item->getId() ?>"
                                :disabled="voted"
                                @click="
                                    if (localStorage.getItem('faq_voted_<?= (int)$item->getId() ?>')) return;
                                    fetch('<?= $block->escapeJs($voteUrl) ?>', {
                                        method: 'POST',
                                        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                                        body: JSON.stringify({item_id: <?= (int)$item->getId() ?>, vote: 'yes'})
                                    }).then(r => r.json()).then(d => {
                                        if (d.success) {
                                            $el.querySelector('.count').textContent = '(' + d.helpful_count + ')';
                                            voted = true;
                                            localStorage.setItem('faq_voted_<?= (int)$item->getId() ?>', 'yes');
                                        }
                                    });
                                ">
                            👍 <?= $block->escapeHtml(__('Yes')) ?>
                            <span class="count">(<?= (int)$item->getHelpfulCount() ?>)</span>
                        </button>
                        <button type="button"
                                class="helpful-btn helpful-no inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg transition disabled:opacity-50"
                                style="background: #fde8e8; color: #991b1b;"
                                data-item-id="<?= (int)$item->getId() ?>"
                                :disabled="voted"
                                @click="
                                    if (localStorage.getItem('faq_voted_<?= (int)$item->getId() ?>')) return;
                                    fetch('<?= $block->escapeJs($voteUrl) ?>', {
                                        method: 'POST',
                                        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                                        body: JSON.stringify({item_id: <?= (int)$item->getId() ?>, vote: 'no'})
                                    }).then(r => r.json()).then(d => {
                                        if (d.success) {
                                            $el.querySelector('.count').textContent = '(' + d.not_helpful_count + ')';
                                            voted = true;
                                            localStorage.setItem('faq_voted_<?= (int)$item->getId() ?>', 'no');
                                        }
                                    });
                                ">
                            👎 <?= $block->escapeHtml(__('No')) ?>
                            <span class="count">(<?= (int)$item->getNotHelpfulCount() ?>)</span>
                        </button>
                    </div>
                </div>
            <?php endif; ?>
        </div>

    <?php else: ?>
        <div class="rounded-lg p-6 text-center" style="background: var(--color-container, #f5f5f5); color: var(--color-fg-secondary, #525252);">
            <?= $block->escapeHtml(__('FAQ item not found.')) ?>
        </div>
        <div class="mt-4">
            <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>"
               class="inline-flex items-center gap-1.5 text-sm"
               style="color: var(--color-primary, #0D9488);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                <?= $block->escapeHtml(__('Back to FAQs')) ?>
            </a>
        </div>
    <?php endif; ?>
</div>
