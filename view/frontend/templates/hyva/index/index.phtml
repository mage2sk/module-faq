<script>
function faqPage() {
    return {
        searchQuery: '',
        searchResults: null,
        searchMode: false,
        searching: false,
        activeCategory: <?= (int)$selectedCategory ?>,
        formKey: '<?= $block->escapeJs($formKey) ?>',

        init() {
            // Handle URL hash — scroll to and open specific FAQ
            if (window.location.hash) {
                const target = document.querySelector(window.location.hash);
                if (target) {
                    setTimeout(() => {
                        const header = target.querySelector('.faq-item-header');
                        if (header) header.click();
                        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }, 200);
                }
            }
        },

        async onSearch() {
            const query = this.searchQuery.trim();
            if (query.length < 2) {
                this.clearSearch();
                return;
            }

            this.searching = true;
            this.searchMode = true;

            try {
                const formData = new FormData();
                formData.append('q', query);
                if (this.activeCategory > 0) {
                    formData.append('category', this.activeCategory);
                }

                const response = await fetch('<?= $block->escapeJs($searchUrl) ?>', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const data = await response.json();
                this.searchResults = data.success ? data.results : [];
            } catch (error) {
                console.error('FAQ search error:', error);
                this.searchResults = [];
            } finally {
                this.searching = false;
            }
        },

        clearSearch() {
            this.searchQuery = '';
            this.searchResults = null;
            this.searchMode = false;
        },

        filterCategory(catId) {
            this.activeCategory = catId;
            // If currently searching, re-search with new category
            if (this.searchMode && this.searchQuery.length >= 2) {
                this.onSearch();
            }
        },

        async submitVote(itemId, voteType) {
            const storageKey = 'faq_voted_' + itemId;
            if (localStorage.getItem(storageKey)) {
                return;
            }

            try {
                const response = await fetch('<?= $block->escapeJs($voteUrl) ?>', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ item_id: itemId, vote: voteType })
                });

                const data = await response.json();
                if (data.success) {
                    // Update count in DOM
                    const btns = document.querySelectorAll('[data-item-id="' + itemId + '"]');
                    btns.forEach(btn => {
                        btn.disabled = true;
                        btn.style.opacity = '0.6';
                    });
                    const activeBtn = document.querySelector('[data-item-id="' + itemId + '"].helpful-' + voteType);
                    if (activeBtn) {
                        const count = activeBtn.querySelector('.count');
                        if (count) {
                            const newCount = voteType === 'yes' ? data.helpful_count : data.not_helpful_count;
                            count.textContent = '(' + newCount + ')';
                        }
                    }
                    localStorage.setItem(storageKey, voteType);
                }
            } catch (error) {
                console.error('Vote error:', error);
            }
        }
    };
}
</script>
