<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    
    <!-- FAQ Categories Table -->
    <table name="panth_faq_category" resource="default" engine="innodb" comment="FAQ Categories">
        <column xsi:type="int" name="category_id" unsigned="true" nullable="false" identity="true" comment="Category ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Category Name"/>
        <column xsi:type="varchar" name="url_key" nullable="false" length="255" comment="URL Key"/>
        <column xsi:type="text" name="description" nullable="true" comment="Category Description"/>
        <column xsi:type="varchar" name="icon" nullable="true" length="255" comment="Category Icon"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="varchar" name="meta_title" nullable="true" length="255" comment="Meta Title"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta Description"/>
        <column xsi:type="text" name="meta_keywords" nullable="true" comment="Meta Keywords"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="category_id"/>
        </constraint>
        <index referenceId="PANTH_FAQ_CATEGORY_URL_KEY" indexType="btree">
            <column name="url_key"/>
        </index>
        <index referenceId="PANTH_FAQ_CATEGORY_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <!-- FAQ Items Table -->
    <table name="panth_faq_item" resource="default" engine="innodb" comment="FAQ Items">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" identity="true" comment="Item ID"/>
        <column xsi:type="varchar" name="question" nullable="false" length="500" comment="Question"/>
        <column xsi:type="text" name="answer" nullable="false" comment="Answer"/>
        <column xsi:type="varchar" name="url_key" nullable="true" length="255" comment="URL Key"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="int" name="view_count" unsigned="true" nullable="false" default="0" comment="View Count"/>
        <column xsi:type="int" name="helpful_count" unsigned="true" nullable="false" default="0" comment="Helpful Count"/>
        <column xsi:type="int" name="not_helpful_count" unsigned="true" nullable="false" default="0" comment="Not Helpful Count"/>
        <column xsi:type="smallint" name="show_on_main" unsigned="true" nullable="false" default="0" comment="Show on Main FAQ Page"/>
        <column xsi:type="varchar" name="meta_title" nullable="true" length="255" comment="Meta Title"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta Description"/>
        <column xsi:type="text" name="meta_keywords" nullable="true" comment="Meta Keywords"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
        </constraint>
        <index referenceId="PANTH_FAQ_ITEM_URL_KEY" indexType="btree">
            <column name="url_key"/>
        </index>
        <index referenceId="PANTH_FAQ_ITEM_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <!-- FAQ Category Store Relation -->
    <table name="panth_faq_category_store" resource="default" engine="innodb" comment="FAQ Category Store Relation">
        <column xsi:type="int" name="category_id" unsigned="true" nullable="false" comment="Category ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" comment="Store ID"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="category_id"/>
            <column name="store_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_CATEGORY_STORE_CATEGORY_ID_PANTH_FAQ_CATEGORY_CATEGORY_ID" 
                    table="panth_faq_category_store" column="category_id" 
                    referenceTable="panth_faq_category" referenceColumn="category_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_CATEGORY_STORE_STORE_ID_STORE_STORE_ID" 
                    table="panth_faq_category_store" column="store_id" 
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_CATEGORY_STORE_STORE_ID" indexType="btree">
            <column name="store_id"/>
        </index>
    </table>

    <!-- FAQ Item Store Relation -->
    <table name="panth_faq_item_store" resource="default" engine="innodb" comment="FAQ Item Store Relation">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" comment="Item ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" comment="Store ID"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
            <column name="store_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_STORE_ITEM_ID_PANTH_FAQ_ITEM_ITEM_ID" 
                    table="panth_faq_item_store" column="item_id" 
                    referenceTable="panth_faq_item" referenceColumn="item_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_STORE_STORE_ID_STORE_STORE_ID" 
                    table="panth_faq_item_store" column="store_id" 
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_ITEM_STORE_STORE_ID" indexType="btree">
            <column name="store_id"/>
        </index>
    </table>

    <!-- FAQ Item Product Relation -->
    <table name="panth_faq_item_product" resource="default" engine="innodb" comment="FAQ Item Product Relation">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" comment="Item ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
            <column name="product_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_PRODUCT_ITEM_ID_PANTH_FAQ_ITEM_ITEM_ID" 
                    table="panth_faq_item_product" column="item_id" 
                    referenceTable="panth_faq_item" referenceColumn="item_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_PRODUCT_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID" 
                    table="panth_faq_item_product" column="product_id" 
                    referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_ITEM_PRODUCT_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
    </table>

    <!-- FAQ Item Category Relation -->
    <table name="panth_faq_item_catalog_category" resource="default" engine="innodb" comment="FAQ Item Catalog Category Relation">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" comment="Item ID"/>
        <column xsi:type="int" name="category_id" unsigned="true" nullable="false" comment="Catalog Category ID"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
            <column name="category_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_CATALOG_CATEGORY_ITEM_ID_PANTH_FAQ_ITEM_ITEM_ID" 
                    table="panth_faq_item_catalog_category" column="item_id" 
                    referenceTable="panth_faq_item" referenceColumn="item_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_CATALOG_CATEGORY_CATEGORY_ID" 
                    table="panth_faq_item_catalog_category" column="category_id" 
                    referenceTable="catalog_category_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_ITEM_CATALOG_CATEGORY_CATEGORY_ID" indexType="btree">
            <column name="category_id"/>
        </index>
    </table>

    <!-- FAQ Item CMS Page Relation -->
    <table name="panth_faq_item_page" resource="default" engine="innodb" comment="FAQ Item CMS Page Relation">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" comment="Item ID"/>
        <column xsi:type="smallint" name="page_id" padding="6" unsigned="false" nullable="false" identity="false" comment="CMS Page ID"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
            <column name="page_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_PAGE_ITEM_ID_PANTH_FAQ_ITEM_ITEM_ID"
                    table="panth_faq_item_page" column="item_id"
                    referenceTable="panth_faq_item" referenceColumn="item_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_PAGE_PAGE_ID_CMS_PAGE_PAGE_ID"
                    table="panth_faq_item_page" column="page_id"
                    referenceTable="cms_page" referenceColumn="page_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_ITEM_PAGE_PAGE_ID" indexType="btree">
            <column name="page_id"/>
        </index>
    </table>

    <!-- FAQ Item FAQ Category Relation (Many-to-Many) -->
    <table name="panth_faq_item_faq_category" resource="default" engine="innodb" comment="FAQ Item FAQ Category Relation">
        <column xsi:type="int" name="item_id" unsigned="true" nullable="false" comment="Item ID"/>
        <column xsi:type="int" name="faq_category_id" unsigned="true" nullable="false" comment="FAQ Category ID"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="item_id"/>
            <column name="faq_category_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_FAQ_CATEGORY_ITEM_ID_PANTH_FAQ_ITEM_ITEM_ID"
                    table="panth_faq_item_faq_category" column="item_id"
                    referenceTable="panth_faq_item" referenceColumn="item_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="PANTH_FAQ_ITEM_FAQ_CATEGORY_FAQ_CATEGORY_ID_PANTH_FAQ_CATEGORY_CATEGORY_ID"
                    table="panth_faq_item_faq_category" column="faq_category_id"
                    referenceTable="panth_faq_category" referenceColumn="category_id" onDelete="CASCADE"/>
        <index referenceId="PANTH_FAQ_ITEM_FAQ_CATEGORY_FAQ_CATEGORY_ID" indexType="btree">
            <column name="faq_category_id"/>
        </index>
    </table>

</schema>
